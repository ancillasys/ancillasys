{
  "name": "control-cartorio",
  "version": "1.2.0",
  "description": "Cartório Control",
  "main": "main.js",
  "author": "Habib",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:protected": "node ofuscar.js && electron-builder"
  },
  "build": {
    "appId": "com.cartorio.control",
    "productName": "Cartório Control",
    "directories": {
      "app": "dist-obfuscated"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icone.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ancillasys",
        "repo": "ancillasys"
      }
    ]
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^25.1.8",
    "javascript-obfuscator": "^5.4.3"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "crypto-js": "^4.2.0",
    "electron-updater": "^6.8.9",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  }
}